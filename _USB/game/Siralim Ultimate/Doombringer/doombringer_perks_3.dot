// Directed graph of reactive effects (cause -> effect) for perks
digraph PerkReactions {
	rankdir=LR;
	node [shape=ellipse, style=filled, fillcolor="/pastel13/1"];

	// Trigger / effect nodes
	on_heal       [label="on-heal"];
	on_death      [label="on-death"];
	on_resurrect  [label="on-resurrect"];
	on_attack     [label="on-attack"];
	on_cast       [label="on-cast"];
	on_defend     [label="on-defend"];
	on_provoke    [label="on-provoke"];
	on_critical   [label="on-critical"];
	on_dodge      [label="on-dodge"];
	on_buff       [label="on-buff"];
	on_debuff     [label="on-debuff"];
	on_minion     [label="on-minion"];
	on_action     [label="on-action"];

	// Outcome / modifier nodes
	avoid_damage       [label="avoid damage / evade"];
	less_damage        [label="take less damage"];
	double_action      [label="double action value"];
	stats_increase     [label="+stats (non-HP)"];
	increased_damage   [label="+damage"];
	resurrect_chance   [label="chance to resurrect"];
	critical_dodge_boost [label="crit & dodge chance"];

	// Edges (cause -> effect) labeled with perk name
	on_heal -> on_death       [label="Anger Management"];
	on_defend -> on_provoke   [label="Aversion"];

	on_attack -> on_attack    [label="Blind Fury (extra triggers)"];
	on_cast   -> on_cast      [label="Blind Fury (extra triggers)"];

	on_heal      -> on_heal       [label="Defiance (extra)"];
	on_death     -> on_death      [label="Defiance (extra)"];
	on_resurrect -> on_resurrect  [label="Defiance (extra)"];

	on_buff   -> avoid_damage    [label="Domination"];
	on_debuff -> avoid_damage    [label="Domination"];
	on_minion -> avoid_damage    [label="Domination"];

	on_defend -> less_damage     [label="Detainment"];
	on_provoke -> less_damage    [label="Detainment"];

	on_attack -> on_resurrect    [label="Eruption"];

	on_action -> double_action   [label="Momentum"];

	on_critical -> on_critical   [label="Obscuration (extra)"];
	on_dodge    -> on_dodge      [label="Obscuration (extra)"];

	on_action -> stats_increase  [label="Outburst"];

	on_critical -> critical_dodge_boost [label="Recklessness"];
	on_dodge    -> critical_dodge_boost [label="Recklessness"];

	on_attack -> increased_damage [label="Siegebreaker"];

	on_heal -> resurrect_chance   [label="Soul Rending"];
	on_death -> resurrect_chance  [label="Soul Rending"];
	on_resurrect -> resurrect_chance [label="Soul Rending"];

	on_buff   -> on_buff    [label="Unbound Hatred (extra)"];
	on_debuff -> on_debuff  [label="Unbound Hatred (extra)"];
	on_minion -> on_minion  [label="Unbound Hatred (extra)"];

	on_defend -> on_defend  [label="Unleashed Power (extra)"];
	on_provoke -> on_provoke [label="Unleashed Power (extra)"];

	on_action -> increased_damage [label="Juggernaut"];

	// layout hints
	{ rank = same; on_heal; on_death; on_resurrect }
	{ rank = same; on_attack; on_cast; on_action }
}

